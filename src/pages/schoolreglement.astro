---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Schoolreglement" description="Het schoolreglement van Sint-Victor Alsemberg.">

  <section class="bg-[#00024c] text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-yellow-400 text-xs font-bold uppercase tracking-wide mb-3">Regels & Afspraken</div>
      <h1 class="text-4xl font-extrabold mb-4">Schoolreglement</h1>
      <p class="text-blue-200 text-lg max-w-2xl">Het schoolreglement beschrijft de rechten en plichten van leerlingen, ouders en school.</p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <div class="bg-yellow-50 border border-yellow-200 rounded-2xl p-6 mb-10 flex gap-4 items-start">
        <div class="text-3xl shrink-0">đź</div>
        <div>
          <div class="font-bold text-[#00024c] mb-1">Schoolreglement 2025-2026</div>
          <p class="text-gray-600 text-sm mb-3">Het volledige schoolreglement is beschikbaar als PDF-document. Je ontvangt dit ook bij inschrijving.</p>
          <a href="#" class="bg-[#00024c] text-white font-bold px-5 py-2 rounded-xl hover:bg-blue-900 transition text-sm inline-block">
            Download schoolreglement (PDF)
          </a>
        </div>
      </div>

      <div class="space-y-8">
        {[
          { titel: "Aanwezigheid & afwezigheid", inhoud: "Leerlingen zijn verplicht aanwezig op alle lessen en activiteiten. Afwezigheid moet gemeld worden via Smartschool of telefonisch vĂłĂłr 8u30. Bij ziekte langer dan 3 opeenvolgende dagen is een doktersattest verplicht." },
          { titel: "Kledij", inhoud: "We vragen nette en respectvolle kledij. Provocerende of aanstootgevende kledij is niet toegestaan. Bij bepaalde lessen (sport, praktijkvakken) is specifieke kledij vereist." },
          { titel: "Elektronische toestellen", inhoud: "Gsm's en andere elektronische toestellen worden bewaard in de locker tijdens de lessen. Gebruik tijdens de les is enkel toegestaan met uitdrukkelijke toestemming van de leerkracht. Het Chromebookproject voorziet een schoolchromebook voor digitale taken." },
          { titel: "Gedrag & respect", inhoud: "We verwachten respectvol gedrag tegenover medeleerlingen, leerkrachten en personeel. Pesten, discriminatie of geweld worden niet getolereerd en leiden tot sancties." },
          { titel: "Punten & evaluatie", inhoud: "Evaluaties verlopen via permanente evaluatie en periodetoetsen. Resultaten worden gecommuniceerd via Smartschool. Ouders worden tijdig geĂŻnformeerd bij zorgsignalen." },
        ].map(s => (
          <div>
            <h2 class="text-xl font-extrabold text-[#00024c] mb-3 flex items-center gap-2">
              <span class="w-1 h-6 bg-yellow-400 rounded-full inline-block"></span>
              {s.titel}
            </h2>
            <p class="text-gray-600 leading-relaxed text-sm pl-4">{s.inhoud}</p>
          </div>
        ))}
      </div>

      <div class="mt-10 bg-[#00024c] text-white rounded-2xl p-6 text-center">
        <p class="text-blue-200 mb-4 text-sm">Vragen over het schoolreglement?</p>
        <a href="/contact" class="bg-yellow-400 text-[#00024c] font-bold px-6 py-3 rounded-xl hover:bg-yellow-300 transition text-sm inline-block">
          Contacteer ons
        </a>
      </div>
    </div>
  </section>

</Layout>
