---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Vacatures" description="Vacatures bij Sint-Victor Alsemberg.">

  <section class="bg-[#07153b] text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-yellow-400 text-xs font-bold uppercase tracking-wide mb-3">Extra</div>
      <h1 class="text-4xl font-extrabold mb-4">Vacatures</h1>
      <p class="text-blue-200 text-lg max-w-2xl">Werken bij Sint-Victor Alsemberg.</p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">

      <div class="bg-gray-50 rounded-2xl p-10 text-center mb-8">
        <div class="bg-[#07153b]/10 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-5">
          <svg class="w-8 h-8 text-[#07153b]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <h2 class="text-xl font-extrabold text-[#07153b] mb-3">Geen openstaande vacatures</h2>
        <p class="text-gray-500 leading-relaxed max-w-md mx-auto">Momenteel zijn er geen openstaande vacatures bij Sint-Victor Alsemberg. Houd deze pagina in de gaten voor toekomstige vacatures.</p>
      </div>

      <div class="bg-[#07153b] text-white rounded-2xl p-8 text-center">
        <h2 class="text-xl font-bold mb-2">Spontane sollicitatie</h2>
        <p class="text-blue-200 text-sm mb-5 max-w-md mx-auto">Ben je geïnteresseerd in een job bij onze school? Stuur gerust een spontane sollicitatie — we houden je kandidatuur bij voor toekomstige vacatures.</p>
        <a href="mailto:solliciteren@sintvictor.be"
          class="bg-yellow-400 text-[#07153b] font-bold px-6 py-3 rounded-xl hover:bg-yellow-300 transition text-sm inline-flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          solliciteren@sintvictor.be
        </a>
      </div>

    </div>
  </section>

</Layout>
