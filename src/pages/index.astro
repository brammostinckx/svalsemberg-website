---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Welkom">

  <!-- Hero -->
  <section class="relative bg-[#00024c] overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute -top-20 -right-20 w-96 h-96 rounded-full bg-yellow-400"></div>
      <div class="absolute bottom-0 -left-10 w-80 h-80 rounded-full bg-blue-400"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-4 py-24 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div class="text-white">
        <div class="inline-flex items-center gap-2 bg-yellow-400/20 border border-yellow-400/40 text-yellow-300 text-xs font-bold px-3 py-1 rounded-full mb-5 uppercase tracking-wide">
          Secundair onderwijs · Alsemberg
        </div>
        <h1 class="text-4xl md:text-5xl font-extrabold leading-tight mb-5">
          Groeien, leren en<br/>
          <span class="text-yellow-400">thuiskomen</span><br/>
          in Alsemberg
        </h1>
        <p class="text-blue-200 text-lg mb-8 leading-relaxed max-w-lg">
          Sint-Victor is een katholieke school met meer dan 150 jaar traditie. Hier voelt elke leerling zich welkom en uitgedaagd om het beste van zichzelf te worden.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/inschrijvingen"
            class="bg-yellow-400 text-[#00024c] font-bold px-7 py-3 rounded-xl hover:bg-yellow-300 transition shadow-lg text-sm">
            Inschrijven 2026-2027
          </a>
          <a href="/onze-school"
            class="bg-white/10 border border-white/30 text-white font-semibold px-7 py-3 rounded-xl hover:bg-white/20 transition text-sm">
            Ontdek de school
          </a>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        {[
          { n: "600+", label: "Leerlingen", icon: "👨‍🎓" },
          { n: "150+", label: "Jaar traditie", icon: "🏫" },
          { n: "15+", label: "Studierichtingen", icon: "📚" },
          { n: "100+", label: "Personeelsleden", icon: "👩‍🏫" },
        ].map(s => (
          <div class="bg-white/10 border border-white/20 rounded-2xl p-5 text-white text-center hover:bg-white/15 transition">
            <div class="text-3xl mb-2">{s.icon}</div>
            <div class="text-2xl font-extrabold text-yellow-400">{s.n}</div>
            <div class="text-xs text-blue-200 mt-1">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Drie pijlers -->
  <section class="py-16 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-[#00024c]">Onze aanpak</h2>
        <div class="w-14 h-1 bg-yellow-400 mx-auto mt-3 rounded-full"></div>
        <p class="text-gray-500 mt-4 max-w-xl mx-auto">Drie woorden vatten samen waar Sint-Victor voor staat.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            tag: "Warm",
            titel: "Iedereen hoort erbij",
            tekst: "We bouwen aan een sterke schoolgemeenschap waar elke leerling zich gezien en gewaardeerd voelt. Geen leerling valt uit de boot.",
            icon: "🤝",
          },
          {
            tag: "Sterk",
            titel: "Leren met stevige basis",
            tekst: "Ambitieus onderwijs met aandacht voor elk leerpad. We bereiden leerlingen voor op hoger onderwijs én op het leven.",
            icon: "📖",
          },
          {
            tag: "Samen",
            titel: "Ouders dichtbij",
            tekst: "Ouders zijn welkome partners in het schoolgebeuren. Open communicatie via Smartschool en regelmatige contactmomenten.",
            icon: "👨‍👩‍👧",
          },
        ].map(p => (
          <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-md transition border-t-4 border-[#00024c] group">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-4xl">{p.icon}</span>
              <span class="bg-[#00024c] text-yellow-400 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">{p.tag}</span>
            </div>
            <h3 class="text-xl font-bold text-[#00024c] mb-3">{p.titel}</h3>
            <p class="text-gray-600 leading-relaxed text-sm">{p.tekst}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Snel naar -->
  <section class="py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-[#00024c]">Snel naar</h2>
        <div class="w-14 h-1 bg-yellow-400 mx-auto mt-3 rounded-full"></div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { href: "/onze-school#team", icon: "👩‍🏫", label: "Schoolteam", beschrijving: "Wie werkt er bij ons?" },
          { href: "/onze-school#visie", icon: "🎯", label: "Onze visie", beschrijving: "Waar staan we voor?" },
          { href: "/studieaanbod", icon: "📚", label: "Studieaanbod", beschrijving: "Alle richtingen" },
          { href: "/schoolreglement", icon: "📋", label: "Schoolreglement", beschrijving: "Regels & afspraken" },
        ].map(k => (
          <a href={k.href}
            class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-md border border-gray-100 hover:border-[#00024c] transition group text-center">
            <div class="text-4xl mb-3">{k.icon}</div>
            <div class="font-bold text-[#00024c] text-sm mb-1">{k.label}</div>
            <div class="text-gray-400 text-xs">{k.beschrijving}</div>
            <div class="mt-3 text-xs text-[#00024c] font-semibold opacity-0 group-hover:opacity-100 transition">Bekijk →</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Praktisch -->
  <section class="py-16 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
      <div>
        <h2 class="text-3xl font-extrabold text-[#00024c] mb-3">Praktisch</h2>
        <div class="w-14 h-1 bg-yellow-400 mb-8 rounded-full"></div>
        <div class="space-y-3">
          {[
            { label: "Vakantiekalender 2025-2026", href: "#" },
            { label: "Schoolreglement", href: "/schoolreglement" },
            { label: "Afwezigheid melden", href: "/afwezigheden" },
            { label: "Infobrochure 2026-2027 (PDF)", href: "#" },
            { label: "Chromebookproject", href: "#" },
            { label: "FAQ — veelgestelde vragen", href: "/faq" },
          ].map(l => (
            <a href={l.href}
              class="flex items-center justify-between bg-white rounded-xl px-5 py-4 shadow-sm hover:shadow-md border border-transparent hover:border-[#00024c] transition group">
              <span class="font-medium text-gray-700 group-hover:text-[#00024c] text-sm transition">{l.label}</span>
              <svg class="w-4 h-4 text-gray-300 group-hover:text-[#00024c] transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ))}
        </div>
      </div>
      <div>
        <h2 class="text-3xl font-extrabold text-[#00024c] mb-3">Digitale tools</h2>
        <div class="w-14 h-1 bg-yellow-400 mb-8 rounded-full"></div>
        <div class="space-y-4">
          <a href="https://sv.smartschool.be" target="_blank" rel="noopener"
            class="flex items-center gap-4 bg-white rounded-xl p-5 shadow-sm hover:shadow-md border border-transparent hover:border-[#00024c] transition group">
            <div class="bg-[#00024c] rounded-xl w-12 h-12 flex items-center justify-center shrink-0">
              <span class="text-yellow-400 font-bold text-sm">SS</span>
            </div>
            <div>
              <div class="font-bold text-[#00024c] text-sm">Smartschool</div>
              <div class="text-gray-400 text-xs">sv.smartschool.be · digitaal leerplatform</div>
            </div>
            <svg class="w-4 h-4 text-gray-300 group-hover:text-[#00024c] ml-auto transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
          <a href="https://instagram.com/sintvictor" target="_blank" rel="noopener"
            class="flex items-center gap-4 bg-white rounded-xl p-5 shadow-sm hover:shadow-md border border-transparent hover:border-pink-400 transition group">
            <div class="bg-gradient-to-br from-pink-500 to-purple-600 rounded-xl w-12 h-12 flex items-center justify-center shrink-0">
              <span class="text-white font-bold text-sm">IG</span>
            </div>
            <div>
              <div class="font-bold text-gray-800 text-sm">Instagram</div>
              <div class="text-gray-400 text-xs">@sintvictor · schoolleven in beelden</div>
            </div>
            <svg class="w-4 h-4 text-gray-300 group-hover:text-pink-400 ml-auto transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
          <a href="https://facebook.com/sintvictor" target="_blank" rel="noopener"
            class="flex items-center gap-4 bg-white rounded-xl p-5 shadow-sm hover:shadow-md border border-transparent hover:border-blue-500 transition group">
            <div class="bg-blue-600 rounded-xl w-12 h-12 flex items-center justify-center shrink-0">
              <span class="text-white font-bold text-sm">FB</span>
            </div>
            <div>
              <div class="font-bold text-gray-800 text-sm">Facebook</div>
              <div class="text-gray-400 text-xs">@sintvictor · nieuws & evenementen</div>
            </div>
            <svg class="w-4 h-4 text-gray-300 group-hover:text-blue-500 ml-auto transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- SV-Tamtam nieuws -->
  <section class="py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="text-3xl font-extrabold text-[#00024c]">SV-Tamtam</h2>
          <div class="w-14 h-1 bg-yellow-400 mt-3 rounded-full"></div>
          <p class="text-gray-500 text-sm mt-3">Het laatste nieuws uit onze school</p>
        </div>
        <a href="/sv-tamtam" class="text-[#00024c] font-semibold text-sm hover:underline">Alle berichten →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            datum: "12 mei 2026",
            tag: "Inschrijvingen",
            titel: "Inschrijvingen 2026-2027 gestart",
            tekst: "Vanaf nu kan je je inschrijven voor het nieuwe schooljaar. Nieuwe leerlingen voor het 1ste jaar en zij-instromers zijn welkom.",
          },
          {
            datum: "29 april 2026",
            tag: "Evenement",
            titel: "Opendeurdag zaterdag 16 mei",
            tekst: "Kom onze school ontdekken! Van 9u tot 12u stellen we alle studierichtingen voor. Leerlingen en leerkrachten tonen je rond.",
          },
          {
            datum: "18 april 2026",
            tag: "SV-Tamtam",
            titel: "13de editie SV-Tamtam beschikbaar",
            tekst: "De nieuwste editie van ons schoolmagazine staat klaar. Boordevol reportages, interviews en foto's van het schoolleven.",
          },
        ].map(b => (
          <article class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition group border border-gray-100">
            <div class="h-1.5 bg-[#00024c] group-hover:bg-yellow-400 transition-colors"></div>
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3">
                <span class="bg-blue-50 text-[#00024c] text-xs font-bold px-2 py-0.5 rounded-full">{b.tag}</span>
                <span class="text-gray-400 text-xs">{b.datum}</span>
              </div>
              <h3 class="font-bold text-[#00024c] text-base mb-2 leading-snug">{b.titel}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{b.tekst}</p>
              <a href="/sv-tamtam" class="mt-4 inline-flex items-center gap-1 text-[#00024c] text-xs font-semibold hover:underline">
                Lees meer <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#00024c] py-16 px-4">
    <div class="max-w-4xl mx-auto text-center text-white">
      <h2 class="text-3xl font-extrabold mb-3">Klaar om deel uit te maken van Sint-Victor?</h2>
      <p class="text-blue-200 text-lg mb-8 max-w-xl mx-auto">
        Schrijf je in voor schooljaar 2026-2027 of kom langs tijdens onze opendeurdag op 16 mei.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/inschrijvingen" class="bg-yellow-400 text-[#00024c] font-bold px-8 py-3 rounded-xl hover:bg-yellow-300 transition">
          Inschrijven
        </a>
        <a href="/contact" class="border-2 border-white/50 text-white font-semibold px-8 py-3 rounded-xl hover:bg-white/10 transition">
          Rondleiding aanvragen
        </a>
      </div>
    </div>
  </section>

</Layout>
