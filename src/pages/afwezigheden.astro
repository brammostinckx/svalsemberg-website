---
import Layout from '../layouts/Layout.astro';
const siteUrl = "https://sites.google.com/sintvictor.be/afwezigheden/";
---
<Layout title="Afwezigheid melden" description="Meld de afwezigheid van uw kind bij Sint-Victor Alsemberg.">

  <section class="bg-[#07153b] text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-yellow-400 text-xs font-bold uppercase tracking-wide mb-3">Praktisch</div>
      <h1 class="text-4xl font-extrabold mb-4">Afwezigheid melden</h1>
      <p class="text-blue-200 text-lg max-w-2xl">Is uw kind ziek of kan het om een andere reden niet naar school? Meld dit via onderstaande link.</p>
    </div>
  </section>

  <section class="py-20 px-4">
    <div class="max-w-xl mx-auto text-center">
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-10">
        <div class="bg-[#07153b] rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <h2 class="text-xl font-extrabold text-[#07153b] mb-3">Afwezigheid doorgeven</h2>
        <p class="text-gray-500 text-sm leading-relaxed mb-8">
          Via onderstaande knop vind je alle informatie en het formulier om een afwezigheid te melden.
        </p>
        <a href={siteUrl} target="_blank" rel="noopener"
          class="inline-block bg-[#07153b] text-white font-bold px-8 py-4 rounded-xl hover:bg-blue-900 transition text-sm">
          Afwezigheid melden &rarr;
        </a>
        <p class="text-xs text-gray-400 mt-4">Opent in een nieuw tabblad</p>
      </div>
    </div>
  </section>

</Layout>
