---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Chromebookproject" description="Het Chromebookproject van Sint-Victor Alsemberg.">

  <section class="bg-[#07153b] text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-yellow-400 text-xs font-bold uppercase tracking-wide mb-3">Extra</div>
      <h1 class="text-4xl font-extrabold mb-4">Chromebookproject</h1>
      <p class="text-blue-200 text-lg max-w-2xl">Informatie over het Chromebookproject van Sint-Victor Alsemberg.</p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <p class="text-gray-500 text-center">Inhoud volgt binnenkort.</p>
    </div>
  </section>

</Layout>
