---
import Layout from '../../layouts/Layout.astro';

const richtingen = [
  {
    naam: "Economie-Moderne Talen",
    kleur: "border-yellow-400 bg-yellow-50",
    tag: "bg-yellow-400 text-[#07153b]",
    beschrijving: "Combinatie van economisch inzicht en sterke talenkennis. Ideaal voor wie zowel cijfers als talen boeit.",
  },
  {
    naam: "Economie-Wiskunde",
    kleur: "border-yellow-500 bg-yellow-50",
    tag: "bg-yellow-500 text-white",
    beschrijving: "Economisch denken versterkt met wiskundige vaardigheden. Goede voorbereiding op economische en exacte studies.",
  },
  {
    naam: "Humane Wetenschappen",
    kleur: "border-[#07153b] bg-blue-50",
    tag: "bg-[#07153b] text-white",
    beschrijving: "Mens, maatschappij en cultuur centraal. Brede vorming in gedragswetenschappen, filosofie en sociale vakken.",
  },
  {
    naam: "Latijn-Moderne Talen",
    kleur: "border-purple-400 bg-purple-50",
    tag: "bg-purple-600 text-white",
    beschrijving: "Klassieke talen gecombineerd met moderne talenkennis. Voor talenliefhebbers met een brede culturele interesse.",
  },
  {
    naam: "Latijn-Wetenschappen",
    kleur: "border-purple-500 bg-purple-50",
    tag: "bg-purple-700 text-white",
    beschrijving: "Klassieke vorming gecombineerd met exacte wetenschappen. Uitstekende voorbereiding op veeleisende universitaire studies.",
  },
  {
    naam: "Moderne Talen-Wetenschappen",
    kleur: "border-blue-400 bg-blue-50",
    tag: "bg-blue-500 text-white",
    beschrijving: "Moderne talen en wetenschappen hand in hand. Voor wie talig én wetenschappelijk sterk wil worden.",
  },
  {
    naam: "Wetenschappen-Wiskunde (6u)",
    kleur: "border-blue-600 bg-blue-50",
    tag: "bg-blue-600 text-white",
    beschrijving: "Intensieve wetenschappelijke en wiskundige vorming. Zes uur wiskunde per week als stevige basis.",
  },
  {
    naam: "Wetenschappen-Wiskunde (8u)",
    kleur: "border-blue-800 bg-blue-50",
    tag: "bg-blue-800 text-white",
    beschrijving: "De meest uitdagende wiskundige richting met acht uur wiskunde per week. Ideaal voor wie wil doorstromen naar exacte of technische studies.",
  },
];

const DOC_ID = '13jSdulxxh6gW_lCR1t5OTB60c4CiNZKa';
---
<Layout title="3de graad — Studieaanbod" description="Studieaanbod 3de graad van Sint-Victor Alsemberg: richtingen, lessentabel en meer.">

  <!-- Hero -->
  <section class="bg-[#07153b] text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-yellow-400 text-xs font-bold uppercase tracking-wide mb-3">Studieaanbod</div>
      <h1 class="text-4xl font-extrabold mb-4">3de graad</h1>
      <p class="text-blue-200 text-lg max-w-2xl">In de derde graad (5de &amp; 6de jaar) verdiepen leerlingen hun ASO-richting en bereiden ze zich voor op het hoger onderwijs.</p>
      <div class="flex flex-wrap gap-3 mt-6">
        <a href="#richtingen" class="bg-yellow-400 text-[#07153b] font-bold px-5 py-2 rounded-xl hover:bg-yellow-300 transition text-sm">Richtingen</a>
        <a href="#lessentabel" class="border border-white/40 text-white font-semibold px-5 py-2 rounded-xl hover:bg-white/10 transition text-sm">Lessentabel</a>
        <a href="#document" class="border border-white/40 text-white font-semibold px-5 py-2 rounded-xl hover:bg-white/10 transition text-sm">Document</a>
      </div>
    </div>
  </section>

  <!-- Richtingen -->
  <section id="richtingen" class="py-16 px-4">
    <div class="max-w-5xl mx-auto">

      <div class="flex items-center gap-3 mb-2">
        <div class="w-1 h-8 bg-yellow-400 rounded-full"></div>
        <h2 class="text-2xl font-extrabold text-[#07153b]">Studierichtingen</h2>
      </div>
      <p class="text-gray-500 text-sm mb-8 pl-4">Alle richtingen zijn ASO met doorstroomfinaliteit naar het hoger onderwijs.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-16">
        {richtingen.map(r => (
          <div class={`rounded-2xl border-l-4 p-6 ${r.kleur}`}>
            <span class={`text-xs font-extrabold px-3 py-1 rounded-full inline-block mb-3 ${r.tag}`}>{r.naam}</span>
            <p class="text-gray-600 text-sm leading-relaxed">{r.beschrijving}</p>
          </div>
        ))}
      </div>

      <!-- Lessentabel -->
      <div id="lessentabel" class="mb-16">
        <h3 class="font-extrabold text-[#07153b] mb-4 text-lg">Lessentabel 3de graad</h3>
        <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-sm">
          <img src="/lessentabellen/3de graad.png" alt="Lessentabel 3de graad" class="w-full h-auto" />
        </div>
      </div>

      <!-- Embedded Drive document -->
      <div id="document">
        <div class="flex items-center justify-between mb-4">
          <h3 class="font-extrabold text-[#07153b] text-lg">Meer informatie</h3>
          <a href={`https://drive.google.com/file/d/${DOC_ID}/view`} target="_blank" rel="noopener"
            class="text-sm text-[#07153b] font-bold hover:underline flex items-center gap-1">
            Openen in Drive
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </div>
        <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-sm" style="height:700px;">
          <iframe
            src={`https://drive.google.com/file/d/${DOC_ID}/preview`}
            class="w-full h-full"
            allow="autoplay"
            title="Document 3de graad Sint-Victor"
          ></iframe>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#07153b] text-white py-12 px-4 text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-xl font-extrabold mb-3">Meer weten over de 3de graad?</h2>
      <p class="text-blue-200 text-sm mb-6">Kom langs op onze opendeurdag of neem contact op met ons secretariaat.</p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/inschrijvingen" class="bg-yellow-400 text-[#07153b] font-bold px-6 py-3 rounded-xl hover:bg-yellow-300 transition text-sm">Inschrijven</a>
        <a href="/contact" class="border border-white/40 text-white font-semibold px-6 py-3 rounded-xl hover:bg-white/10 transition text-sm">Contact</a>
        <a href="/studieaanbod" class="border border-white/40 text-white font-semibold px-6 py-3 rounded-xl hover:bg-white/10 transition text-sm">&larr; Alle richtingen</a>
      </div>
    </div>
  </section>

</Layout>
