---
import Layout from '../layouts/Layout.astro';
const FOLDER_ID = '1-XYeqjkuNCGUcYoMdHlPVifV-OTbczwq';
const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbydmbI4Xt1T6lLjDjmmNka7B9xhxKYtqbg-vrQPlkOfSE4yVQzHsCu0KTNGmPxMH210yg/exec';
---
<Layout title="SV-Tamtam" description="Alle edities van het SV-Tamtam schoolmagazine van Sint-Victor Alsemberg.">

  <section class="bg-[#07153b] text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-yellow-400 text-xs font-bold uppercase tracking-wide mb-3">Schoolmagazine</div>
      <h1 class="text-4xl font-extrabold mb-4">SV-Tamtam</h1>
      <p class="text-blue-200 text-lg max-w-2xl">Het schoolmagazine van Sint-Victor Alsemberg. Alle edities beschikbaar als PDF.</p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto">

      <!-- Laatste editie knop (gevuld via JS) -->
      <div id="laatste-editie-blok" class="hidden mb-10">
        <div class="bg-[#07153b] rounded-2xl p-6 flex flex-col sm:flex-row items-center gap-5">
          <div class="bg-yellow-400 rounded-xl w-14 h-14 flex items-center justify-center shrink-0">
            <svg class="w-7 h-7 text-[#07153b]" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM6 20V4h5v7h7v9H6z"/>
            </svg>
          </div>
          <div class="flex-1 text-center sm:text-left">
            <div class="text-yellow-400 text-xs font-bold uppercase tracking-wide mb-1">Nieuwste editie</div>
            <div id="laatste-editie-naam" class="text-white font-extrabold text-lg"></div>
          </div>
          <a id="laatste-editie-link" href="#" target="_blank" rel="noopener"
            class="bg-yellow-400 text-[#07153b] font-bold px-6 py-3 rounded-xl hover:bg-yellow-300 transition text-sm shrink-0 whitespace-nowrap">
            Lees de laatste editie &rarr;
          </a>
        </div>
      </div>

      <div class="flex items-center justify-between mb-2">
        <h2 class="text-2xl font-extrabold text-[#07153b]">Alle edities</h2>
        <a href={`https://drive.google.com/drive/folders/${FOLDER_ID}`} target="_blank" rel="noopener"
          class="text-sm text-[#07153b] font-bold hover:underline flex items-center gap-1">
          Openen in Drive
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
      </div>
      <div class="w-14 h-1 bg-yellow-400 mb-6 rounded-full"></div>

      <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-sm">
        <iframe
          src={`https://drive.google.com/embeddedfolderview?id=${FOLDER_ID}#list`}
          class="w-full"
          style="height: 600px; border: none;"
          title="SV-Tamtam archief"
        ></iframe>
      </div>

      <p class="text-xs text-gray-400 mt-3 text-center">
        Klik op een editie om ze te openen. Het archief wordt automatisch bijgewerkt wanneer er een nieuwe editie verschijnt.
      </p>

    </div>
  </section>

</Layout>

<script define:vars={{ APPS_SCRIPT_URL }}>
  async function laadLaatsteEditie() {
    try {
      const res = await fetch(APPS_SCRIPT_URL);
      const data = await res.json();
      if (!res.ok || !data.id) return;

      const naam = data.name;
      const link = `https://drive.google.com/file/d/${data.id}/view`;

      document.getElementById('laatste-editie-naam').textContent = naam;
      document.getElementById('laatste-editie-link').href = link;
      document.getElementById('laatste-editie-blok').classList.remove('hidden');
    } catch {
      // stil falen — blok blijft verborgen
    }
  }

  laadLaatsteEditie();
</script>
