---
import Layout from '../layouts/Layout.astro';
const berichten = [
  { datum: "12 mei 2026", tag: "Inschrijvingen", titel: "Inschrijvingen 2026-2027 gestart", tekst: "Vanaf nu kan je je inschrijven voor het nieuwe schooljaar. Nieuwe leerlingen voor het 1ste jaar en zij-instromers zijn welkom. Meer info op de inschrijvingenpagina." },
  { datum: "29 april 2026", tag: "Evenement", titel: "Opendeurdag zaterdag 16 mei", tekst: "Kom onze school ontdekken! Van 9u tot 12u stellen we alle studierichtingen voor. Leerlingen en leerkrachten tonen je rond en beantwoorden al je vragen." },
  { datum: "18 april 2026", tag: "SV-Tamtam", titel: "13de editie SV-Tamtam beschikbaar", tekst: "De nieuwste editie van ons schoolmagazine staat klaar. Boordevol reportages, interviews en foto's van het schoolleven. Vraag een exemplaar aan het secretariaat." },
  { datum: "5 april 2026", tag: "Schoolleven", titel: "Paasactie voor het goede doel", tekst: "Onze leerlingen organiseerden een paasmarkt ten voordele van een goed doel. Er werd meer dan 1.500 euro ingezameld. Een geweldig resultaat!" },
  { datum: "20 maart 2026", tag: "Project", titel: "AED-project: leerlingen leren reanimeren", tekst: "In het kader van ons AED-project leerden meer dan 200 leerlingen hoe ze moeten reanimeren. Een levensreddende vaardigheid voor iedereen." },
  { datum: "10 maart 2026", tag: "Infrastructuur", titel: "Nieuwe Chromebooks voor alle leerlingen", tekst: "In het kader van ons Chromebookproject beschikt elke leerling nu over een persoonlijk toestel. Dit maakt digitaal leren toegankelijker dan ooit." },
];
---
<Layout title="SV-Tamtam" description="Nieuws en evenementen van Sint-Victor Alsemberg.">

  <section class="bg-[#07153b] text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-yellow-400 text-xs font-bold uppercase tracking-wide mb-3">Nieuws & Mededelingen</div>
      <h1 class="text-4xl font-extrabold mb-4">SV-Tamtam</h1>
      <p class="text-blue-200 text-lg max-w-2xl">Blijf op de hoogte van alles wat leeft op onze school.</p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto space-y-5">
      {berichten.map(b => (
        <article class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition group">
          <div class="flex items-center gap-3 mb-3">
            <span class="bg-blue-50 text-[#07153b] text-xs font-bold px-3 py-1 rounded-full">{b.tag}</span>
            <span class="text-gray-400 text-xs">{b.datum}</span>
          </div>
          <h2 class="text-xl font-bold text-[#07153b] mb-2 group-hover:text-blue-800 transition">{b.titel}</h2>
          <p class="text-gray-600 leading-relaxed text-sm">{b.tekst}</p>
        </article>
      ))}
    </div>
  </section>

</Layout>
