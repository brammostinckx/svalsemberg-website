---
import Layout from '../layouts/Layout.astro';
const FOLDER_ID = '1-XYeqjkuNCGUcYoMdHlPVifV-OTbczwq';
---
<Layout title="SV-Tamtam" description="Alle edities van het SV-Tamtam schoolmagazine van Sint-Victor Alsemberg.">

  <section class="bg-[#07153b] text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-yellow-400 text-xs font-bold uppercase tracking-wide mb-3">Schoolmagazine</div>
      <h1 class="text-4xl font-extrabold mb-4">SV-Tamtam</h1>
      <p class="text-blue-200 text-lg max-w-2xl">Het schoolmagazine van Sint-Victor Alsemberg. Alle edities beschikbaar als PDF.</p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto">

      <div class="flex items-center justify-between mb-2">
        <h2 class="text-2xl font-extrabold text-[#07153b]">Alle edities</h2>
        <a href={`https://drive.google.com/drive/folders/${FOLDER_ID}`} target="_blank" rel="noopener"
          class="text-sm text-[#07153b] font-bold hover:underline flex items-center gap-1">
          Openen in Drive
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
      </div>
      <div class="w-14 h-1 bg-yellow-400 mb-6 rounded-full"></div>

      <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-sm">
        <iframe
          src={`https://drive.google.com/embeddedfolderview?id=${FOLDER_ID}#list`}
          class="w-full"
          style="height: 600px; border: none;"
          title="SV-Tamtam archief"
        ></iframe>
      </div>

      <p class="text-xs text-gray-400 mt-3 text-center">
        Klik op een editie om ze te openen. Het archief wordt automatisch bijgewerkt wanneer er een nieuwe editie verschijnt.
      </p>

    </div>
  </section>

</Layout>
