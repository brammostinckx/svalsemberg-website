---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact" description="Neem contact op met Sint-Victor Alsemberg.">

  <section class="bg-[#00024c] text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold mb-4">Contact</h1>
      <p class="text-blue-200 text-lg">We horen graag van je!</p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12">

      <!-- Contactgegevens -->
      <div>
        <h2 class="text-2xl font-bold text-[#00024c] mb-6">Gegevens</h2>
        <div class="space-y-4">
          <div class="flex gap-4 items-start">
            <div class="bg-[#00024c] text-white rounded-full w-10 h-10 flex items-center justify-center shrink-0">📍</div>
            <div>
              <div class="font-semibold">Adres</div>
              <div class="text-gray-600">Alsembergsteenweg 613<br/>1653 Dworp (Alsemberg)</div>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <div class="bg-[#00024c] text-white rounded-full w-10 h-10 flex items-center justify-center shrink-0">✉️</div>
            <div>
              <div class="font-semibold">E-mail</div>
              <a href="mailto:info@svalsemberg.be" class="text-[#00024c] hover:underline">info@svalsemberg.be</a>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <div class="bg-[#00024c] text-white rounded-full w-10 h-10 flex items-center justify-center shrink-0">🕐</div>
            <div>
              <div class="font-semibold">Secretariaat</div>
              <div class="text-gray-600">Ma–Vr: 8u00 – 16u30</div>
            </div>
          </div>
        </div>

        <div class="mt-8 bg-gray-50 rounded-2xl p-6">
          <h3 class="font-bold text-[#00024c] mb-3">Rondleiding aanvragen</h3>
          <p class="text-gray-600 text-sm">Wil je onze school persoonlijk ontdekken? Stuur een e-mail naar <a href="mailto:info@svalsemberg.be" class="text-[#00024c] font-semibold">info@svalsemberg.be</a> en we plannen graag een moment in.</p>
        </div>
      </div>

      <!-- Contactformulier -->
      <div>
        <h2 class="text-2xl font-bold text-[#00024c] mb-6">Stuur ons een bericht</h2>
        <form class="space-y-4" name="contact" method="POST" data-netlify="true">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="naam">Naam</label>
            <input id="naam" name="naam" type="text" required
              class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#00024c] transition" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="email">E-mail</label>
            <input id="email" name="email" type="email" required
              class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#00024c] transition" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="onderwerp">Onderwerp</label>
            <input id="onderwerp" name="onderwerp" type="text"
              class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#00024c] transition" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="bericht">Bericht</label>
            <textarea id="bericht" name="bericht" rows="5" required
              class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#00024c] transition resize-none"></textarea>
          </div>
          <button type="submit"
            class="w-full bg-[#00024c] text-white font-bold py-3 rounded-xl hover:bg-blue-900 transition">
            Verstuur bericht
          </button>
        </form>
      </div>

    </div>
  </section>

</Layout>
