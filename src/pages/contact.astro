---
import Layout from '../layouts/Layout.astro';
const gegevens = [
  { label: "Adres", waarde: "Brusselsesteenweg 20\n1652 Alsemberg" },
  { label: "Telefoon", waarde: "02/380.15.89" },
  { label: "Algemeen", waarde: "info@sintvictor.be" },
  { label: "Solliciteren", waarde: "solliciteren@sintvictor.be" },
  { label: "Secretariaat", waarde: "Ma-Vr: 8u00 - 16u30" },
];
---
<Layout title="Contact" description="Contactgegevens van Sint-Victor Alsemberg.">

  <section class="bg-[#07153b] text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-yellow-400 text-xs font-bold uppercase tracking-wide mb-3">Sint-Victor Alsemberg</div>
      <h1 class="text-4xl font-extrabold mb-4">Contact</h1>
      <p class="text-blue-200 text-lg max-w-2xl">We horen graag van je. Ons secretariaat staat je graag te woord.</p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12">

      <div>
        <h2 class="text-2xl font-extrabold text-[#07153b] mb-6">Gegevens</h2>
        <div class="space-y-3 mb-8">
          {gegevens.map(c => (
            <div class="flex gap-4 items-start bg-gray-50 rounded-xl p-4">
              <div class="w-1.5 h-full min-h-4 bg-yellow-400 rounded-full shrink-0 mt-1"></div>
              <div>
                <div class="text-xs font-bold text-gray-400 uppercase tracking-wide mb-0.5">{c.label}</div>
                <div class="text-gray-700 text-sm whitespace-pre-line">{c.waarde}</div>
              </div>
            </div>
          ))}
        </div>

        <h3 class="font-extrabold text-[#07153b] mb-4">Directie</h3>
        <div class="space-y-3">
          {[
            { naam: "Nele Neyt", rol: "Directeur 1ste graad" },
            { naam: "Kevin Swaelens", rol: "Directeur 2de & 3de graad" },
          ].map(d => (
            <div class="flex items-center gap-4 bg-gray-50 rounded-xl p-4">
              <div class="bg-[#07153b] rounded-full w-10 h-10 flex items-center justify-center shrink-0">
                <span class="text-yellow-400 font-bold text-xs">{d.naam.split(' ').map((n: string) => n[0]).join('')}</span>
              </div>
              <div>
                <div class="font-bold text-[#07153b] text-sm">{d.naam}</div>
                <div class="text-gray-500 text-xs">{d.rol}</div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-8 bg-[#07153b] text-white rounded-2xl p-5">
          <div class="font-bold text-yellow-400 mb-2 text-sm">Digitale platforms</div>
          <div class="space-y-2 text-sm text-blue-200">
            <div>Smartschool: <a href="https://sv.smartschool.be" target="_blank" rel="noopener" class="text-white hover:text-yellow-300 transition">sv.smartschool.be</a></div>
            <div>Instagram: <a href="https://instagram.com/sintvictor" target="_blank" rel="noopener" class="text-white hover:text-yellow-300 transition">@sintvictor</a></div>
            <div>Facebook: <a href="https://facebook.com/sintvictor" target="_blank" rel="noopener" class="text-white hover:text-yellow-300 transition">@sintvictor</a></div>
          </div>
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-extrabold text-[#07153b] mb-6">Stuur ons een bericht</h2>
        <form class="space-y-4" action="https://api.web3forms.com/submit" method="POST">
          <input type="hidden" name="access_key" value="c45abed7-7b00-40ad-92a2-3db65d9405bd" />
          <input type="hidden" name="subject" value="Nieuw bericht via de website van Sint-Victor" />
          <input type="hidden" name="from_name" value="Sint-Victor Website" />
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
          <div>
            <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-1" for="naam">Naam</label>
            <input id="naam" name="naam" type="text" required placeholder="Voornaam en naam"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#07153b] transition bg-gray-50" />
          </div>
          <div>
            <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-1" for="email">E-mail</label>
            <input id="email" name="email" type="email" required placeholder="jouw@email.be"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#07153b] transition bg-gray-50" />
          </div>
          <div>
            <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-1" for="onderwerp">Onderwerp</label>
            <select id="onderwerp" name="onderwerp"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#07153b] transition bg-gray-50">
              <option value="">Kies een onderwerp...</option>
              <option>Inschrijvingen</option>
              <option>Studieaanbod</option>
              <option>Afwezigheid</option>
              <option>Praktische info</option>
              <option>Andere</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-1" for="bericht">Bericht</label>
            <textarea id="bericht" name="bericht" rows="5" required placeholder="Jouw bericht..."
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#07153b] transition bg-gray-50 resize-none"></textarea>
          </div>
          <input type="hidden" name="redirect" value="https://svalsemberg-website.lucky-frost-7e00.workers.dev/contact?verzonden=1" />
          <button type="submit" class="w-full bg-[#07153b] text-white font-bold py-3 rounded-xl hover:bg-blue-900 transition text-sm">
            Verstuur bericht
          </button>
        </form>

        {Astro.url.searchParams.get('verzonden') === '1' && (
          <div class="mt-4 bg-green-50 border border-green-200 rounded-xl px-5 py-4 text-green-800 text-sm font-medium flex items-center gap-3">
            <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Je bericht is verstuurd! We nemen zo snel mogelijk contact met je op.
          </div>
        )}
      </div>
    </div>
  </section>

</Layout>
