---
import Layout from '../layouts/Layout.astro';
const graden = [
  {
    id: "eerste-graad",
    graad: "1ste graad",
    subtitel: "1ste & 2de jaar",
    kleur: "border-[#07153b]",
    bg: "bg-blue-50",
    beschrijving: "De eerste graad vormt de brug tussen het lager onderwijs en het secundair. We bieden een brede oriëntering waarbij leerlingen hun talenten en interesses kunnen ontdekken via drie unieke pijlers: FLEX, WIJS en TALENT.",
    link: "/studieaanbod/eerste-graad",
    linkTekst: "Volledig aanbod 1ste graad",
    opties: [
      { naam: "A-stroom", beschrijving: "Brede algemene vorming als voorbereiding op de ASO-richtingen van de 2de graad." },
    ],
  },
  {
    id: "tweede-graad",
    graad: "2de graad",
    subtitel: "3de & 4de jaar",
    kleur: "border-yellow-400",
    bg: "bg-yellow-50",
    beschrijving: "In de tweede graad kiezen leerlingen een ASO-studierichting die aansluit bij hun talenten en toekomstplannen. Alle richtingen bereiden voor op het hoger onderwijs.",
    link: "/studieaanbod/tweede-graad",
    linkTekst: "Volledig aanbod 2de graad",
    opties: [
      { naam: "Humane wetenschappen", beschrijving: "Mens en maatschappij centraal. Talenkennis, filosofie en sociale wetenschappen." },
      { naam: "Economische wetenschappen", beschrijving: "Economie, bedrijfswetenschappen en wiskunde als rode draad." },
      { naam: "Latijn", beschrijving: "Klassieke talen en cultuur als fundament voor een brede algemene vorming." },
      { naam: "Natuurwetenschappen", beschrijving: "Exacte wetenschappen: wiskunde, fysica, biologie en chemie." },
    ],
  },
  {
    id: "derde-graad",
    graad: "3de graad",
    subtitel: "5de & 6de jaar",
    kleur: "border-[#07153b]",
    bg: "bg-blue-50",
    beschrijving: "De derde graad bereidt leerlingen voor op het hoger onderwijs. Alle richtingen zijn ASO met een sterke doorstroomfinaliteit.",
    link: "/studieaanbod/derde-graad",
    linkTekst: "Volledig aanbod 3de graad",
    opties: [
      { naam: "Economie-Moderne Talen", beschrijving: "Economisch inzicht gecombineerd met sterke talenkennis." },
      { naam: "Economie-Wiskunde", beschrijving: "Economisch denken versterkt met wiskundige vaardigheden." },
      { naam: "Humane Wetenschappen", beschrijving: "Mens, maatschappij en cultuur centraal." },
      { naam: "Latijn-Moderne Talen", beschrijving: "Klassieke en moderne talen voor talenliefhebbers." },
      { naam: "Latijn-Wetenschappen", beschrijving: "Klassieke vorming gecombineerd met exacte wetenschappen." },
      { naam: "Moderne Talen-Wetenschappen", beschrijving: "Talig én wetenschappelijk sterk worden." },
      { naam: "Wetenschappen-Wiskunde (6u)", beschrijving: "Intensieve wetenschappelijke en wiskundige vorming." },
      { naam: "Wetenschappen-Wiskunde (8u)", beschrijving: "De meest uitdagende wiskundige richting." },
    ],
  },
];
---
<Layout title="Studieaanbod" description="Alle studierichtingen van Sint-Victor Alsemberg per graad.">

  <section class="bg-[#07153b] text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-yellow-400 text-xs font-bold uppercase tracking-wide mb-3">Sint-Victor Alsemberg</div>
      <h1 class="text-4xl font-extrabold mb-4">Studieaanbod</h1>
      <p class="text-blue-200 text-lg max-w-2xl">Van eerste graad tot zesde jaar &mdash; een volledig ASO-aanbod voor elk talent.</p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto space-y-16">
      {graden.map(g => (
        <div id={g.id}>
          <div class="flex items-center gap-4 mb-6">
            <div class="w-1 h-12 rounded-full bg-[#07153b]"></div>
            <div>
              <div class="text-yellow-500 text-xs font-bold uppercase tracking-wide">{g.subtitel}</div>
              <h2 class="text-2xl font-extrabold text-[#07153b]">{g.graad}</h2>
            </div>
          </div>
          <p class="text-gray-600 mb-6 leading-relaxed max-w-2xl">{g.beschrijving}</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-5">
            {g.opties.map((o: { naam: string; beschrijving: string }) => (
              <div class={`rounded-xl border-l-4 ${g.kleur} ${g.bg} p-5 hover:shadow-sm transition`}>
                <div class="font-bold text-[#07153b] mb-1 text-sm">{o.naam}</div>
                <div class="text-gray-600 text-xs leading-relaxed">{o.beschrijving}</div>
              </div>
            ))}
          </div>
          {'link' in g && g.link && (
            <a href={g.link} class="inline-flex items-center gap-2 bg-[#07153b] text-white font-bold px-5 py-2.5 rounded-xl hover:bg-blue-900 transition text-sm">
              {(g as any).linkTekst} &rarr;
            </a>
          )}
        </div>
      ))}

      <div class="bg-[#07153b] text-white rounded-2xl p-8 text-center">
        <h2 class="text-2xl font-bold mb-3">Twijfel je welke richting past bij jou?</h2>
        <p class="text-blue-200 mb-6 max-w-xl mx-auto">Onze leerlingenbegeleiding helpt je graag bij de studiekeuze. Maak een afspraak of kom langs tijdens de opendeurdag.</p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="/contact" class="bg-yellow-400 text-[#07153b] font-bold px-6 py-3 rounded-xl hover:bg-yellow-300 transition">Afspraak maken</a>
          <a href="/inschrijvingen" class="border border-white/40 text-white font-semibold px-6 py-3 rounded-xl hover:bg-white/10 transition">Inschrijven</a>
        </div>
      </div>
    </div>
  </section>

</Layout>
