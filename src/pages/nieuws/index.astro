---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const items = (await getCollection('nieuws'))
  .filter(i => i.data.gepubliceerd !== false)
  .sort((a, b) => new Date(b.data.datum).getTime() - new Date(a.data.datum).getTime());

function formatDatum(d: string) {
  return new Date(d).toLocaleDateString('nl-BE', { day: 'numeric', month: 'long', year: 'numeric' });
}
---
<Layout title="Nieuws" description="Alle nieuwtjes van Sint-Victor Alsemberg.">

  <section class="bg-[#07153b] text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-yellow-400 text-xs font-bold uppercase tracking-wide mb-3">Sint-Victor Alsemberg</div>
      <h1 class="text-4xl font-extrabold mb-4">Nieuws</h1>
      <p class="text-blue-200 text-lg max-w-2xl">Alle nieuwsberichten van onze school.</p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {items.map(item => {
          const href = item.data.internalLink || item.data.link || `/nieuws/${item.id}`;
          const extern = !!item.data.link && !item.data.internalLink;
          return (
            <a href={href} target={extern ? '_blank' : undefined} rel={extern ? 'noopener' : undefined}
              class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group border border-gray-100 flex flex-col">
              <div class="h-1.5 bg-[#07153b] group-hover:bg-yellow-400 transition-colors"></div>
              <div class="p-6 flex flex-col flex-1">
                <div class="flex items-center gap-2 mb-3">
                  <span class="bg-blue-50 text-[#07153b] text-xs font-bold px-2 py-0.5 rounded-full">{item.data.tag}</span>
                  <span class="text-gray-400 text-xs">{formatDatum(item.data.datum)}</span>
                </div>
                <h2 class="font-bold text-[#07153b] text-base mb-2 leading-snug">{item.data.titel}</h2>
                <p class="text-gray-500 text-sm leading-relaxed flex-1">{item.data.samenvatting}</p>
                <div class="mt-4 inline-flex items-center gap-1 text-[#07153b] text-xs font-semibold group-hover:underline">
                  Lees meer
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

</Layout>
