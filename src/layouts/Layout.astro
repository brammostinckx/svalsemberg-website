---
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Sint-Victor Alsemberg — secundair onderwijs met hart voor elke leerling" } = Astro.props;
const currentPath = Astro.url.pathname;
const nav = [
  { label: "Start", href: "/" },
  { label: "Onze school", href: "/onze-school", sub: [
    { label: "Visie & missie", href: "/onze-school" },
    { label: "Schoolreglement", href: "/schoolreglement" },
  ]},
  { label: "Studieaanbod", href: "/studieaanbod", sub: [
    { label: "1ste graad", href: "/studieaanbod/eerste-graad" },
    { label: "2de graad", href: "/studieaanbod/tweede-graad" },
    { label: "3de graad", href: "/studieaanbod/derde-graad" },
  ]},
  { label: "SV-Nieuws", href: "/sv-tamtam" },
  { label: "FAQ", href: "/faq" },
  { label: "Extra", href: "#", sub: [
    { label: "Chromebookproject", href: "/chromebookproject" },
    { label: "SV-Tamtam", href: "/sv-tamtam" },
    { label: "AED-project", href: "/aed-project" },
    { label: "Vacatures", href: "/vacatures" },
  ]},
  { label: "Contact", href: "/contact" },
];
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title} | Sint-Victor Alsemberg</title>
  </head>
  <body class="bg-white text-gray-800" style="font-family: 'Inter', sans-serif;">

    <!-- Topbalk -->
    <div class="bg-[#07153b] text-white text-xs py-2 px-4 hidden md:flex">
      <div class="max-w-6xl mx-auto w-full flex justify-between items-center">
        <div class="flex items-center gap-6">
          <span>📍 Brusselsesteenweg 20, 1652 Alsemberg</span>
          <a href="mailto:info@sintvictor.be" class="hover:text-yellow-300 transition flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            info@sintvictor.be
          </a>
          <a href="tel:+3223801589" class="hover:text-yellow-300 transition flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            02 380 15 89
          </a>
        </div>
        <div class="flex items-center gap-4">
          <a href="https://sv.smartschool.be" target="_blank" rel="noopener" class="hover:text-yellow-300 transition">Smartschool</a>
          <span class="text-blue-400">|</span>
          <a href="https://sites.google.com/sintvictor.be/afwezigheden/" target="_blank" rel="noopener" class="hover:text-yellow-300 transition">Afwezigheid melden</a>
        </div>
      </div>
    </div>

    <!-- Header -->
    <header class="bg-white shadow-sm sticky top-0 z-50 border-b-4 border-[#07153b]">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 hover:opacity-80 transition">
          <img src="/logo-cropped.png" alt="Sint-Victor Alsemberg" class="h-12 w-auto" />
        </a>

        <nav class="hidden lg:flex items-center gap-1">
          {nav.map(item => (
            <div class="relative group">
              <a href={item.href}
                class={`px-3 py-2 rounded-lg font-semibold text-sm transition flex items-center gap-1 ${currentPath === item.href ? 'text-[#07153b] bg-blue-50' : 'text-gray-700 hover:text-[#07153b] hover:bg-blue-50'}`}>
                {item.label}
                {item.sub && item.sub.length > 0 && (
                  <svg class="w-3 h-3 text-gray-400 group-hover:text-[#07153b] transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                )}
              </a>
              {item.sub && item.sub.length > 0 && (
                <div class="absolute top-full left-0 mt-1 bg-white rounded-xl shadow-xl border border-gray-100 py-2 min-w-52 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50">
                  {item.sub.map(s => (
                    <a href={s.href} class="block px-4 py-2 text-sm text-gray-600 hover:text-[#07153b] hover:bg-blue-50 transition">{s.label}</a>
                  ))}
                </div>
              )}
            </div>
          ))}
          <a href="/inschrijvingen" class="ml-2 bg-yellow-400 text-[#07153b] font-bold text-sm px-4 py-2 rounded-lg hover:bg-yellow-300 transition">
            Inschrijven →
          </a>
        </nav>

        <button id="menu-toggle" class="lg:hidden p-2 rounded-lg hover:bg-gray-100 transition">
          <svg class="w-6 h-6 text-[#07153b]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 px-4 py-3 space-y-1 bg-white">
        {nav.map(item => (
          <a href={item.href} class="block px-3 py-2 rounded-lg text-sm font-semibold text-gray-700 hover:text-[#07153b] hover:bg-blue-50 transition">{item.label}</a>
        ))}
        <a href="/inschrijvingen" class="block mt-2 bg-yellow-400 text-[#07153b] font-bold text-sm px-4 py-2 rounded-lg text-center">Inschrijven →</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="bg-[#07153b] text-white mt-0">
      <div class="max-w-6xl mx-auto px-4 py-12 grid grid-cols-1 md:grid-cols-4 gap-8">
        <div class="md:col-span-2">
          <div class="flex items-center gap-3 mb-4">
            <img src="/logo-cropped.png" alt="Sint-Victor Alsemberg" class="h-10 w-auto brightness-0 invert" />
          </div>
          <p class="text-blue-200 text-sm leading-relaxed max-w-xs mb-4">
            "Honor Deo, Labor mihi, Utilitas proximo" — een katholieke school met meer dan 150 jaar traditie.
          </p>
          <div class="flex gap-3 flex-wrap">
            <a href="https://instagram.com/sintvictor" target="_blank" rel="noopener"
              class="bg-white/10 hover:bg-white/20 transition px-3 py-1 rounded-lg text-xs font-medium">Instagram</a>
            <a href="https://facebook.com/sintvictor" target="_blank" rel="noopener"
              class="bg-white/10 hover:bg-white/20 transition px-3 py-1 rounded-lg text-xs font-medium">Facebook</a>
            <a href="https://www.youtube.com/@SintVictorAlsemberg" target="_blank" rel="noopener"
              class="bg-white/10 hover:bg-white/20 transition px-3 py-1 rounded-lg text-xs font-medium">YouTube</a>
            <a href="https://sv.smartschool.be" target="_blank" rel="noopener"
              class="bg-white/10 hover:bg-white/20 transition px-3 py-1 rounded-lg text-xs font-medium">Smartschool</a>
          </div>
        </div>
        <div>
          <div class="font-bold mb-3 text-yellow-400 text-sm uppercase tracking-wide">Navigatie</div>
          <ul class="space-y-2 text-sm text-blue-200">
            <li><a href="/onze-school" class="hover:text-white transition">Onze school</a></li>
            <li><a href="/studieaanbod" class="hover:text-white transition">Studieaanbod</a></li>
            <li><a href="/inschrijvingen" class="hover:text-white transition">Inschrijvingen</a></li>
            <li><a href="/sv-tamtam" class="hover:text-white transition">SV-Tamtam</a></li>
            <li><a href="/schoolreglement" class="hover:text-white transition">Schoolreglement</a></li>
            <li><a href="/faq" class="hover:text-white transition">FAQ</a></li>
            <li><a href="/contact" class="hover:text-white transition">Contact</a></li>
          </ul>
        </div>
        <div>
          <div class="font-bold mb-3 text-yellow-400 text-sm uppercase tracking-wide">Contact</div>
          <ul class="space-y-2 text-sm text-blue-200">
            <li>Brusselsesteenweg 20</li>
            <li>1652 Alsemberg</li>
            <li class="pt-1"><a href="tel:+3223801589" class="hover:text-white transition">02/380.15.89</a></li>
            <li><a href="mailto:info@sintvictor.be" class="hover:text-white transition">info@sintvictor.be</a></li>
            <li class="pt-1 text-xs">
              <span class="block font-medium text-white">Directie 1ste graad:</span>
              Nele Neyt
            </li>
            <li class="text-xs">
              <span class="block font-medium text-white">Directie 2de &amp; 3de graad:</span>
              Kevin Swaelens
            </li>
          </ul>
        </div>
      </div>
      <div class="border-t border-white/10 text-center text-blue-400 text-xs py-4">
        © {new Date().getFullYear()} Sint-Victor Alsemberg · <a href="/schoolreglement" class="hover:text-white transition">Schoolreglement</a> · <a href="/privacy" class="hover:text-white transition">Privacy</a>
      </div>
    </footer>

    <script>
      document.getElementById('menu-toggle')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
